<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>CHINAMIDIA</title>

<style>
body {
  margin: 0;
  font-family: Arial;
  background: #1a0033;
  color: white;
}

/* MENU */
nav {
  background: #6A0DAD;
  padding: 15px;
  display: flex;
  justify-content: space-around;
  font-weight: bold;
}

nav a {
  color: white;
  text-decoration: none;
}

/* HEADER */
header {
  text-align: center;
  padding: 40px;
}

header h1 {
  font-size: 40px;
}

/* CARDS */
.container {
  padding: 20px;
}

.box {
  background: #2a004d;
  margin: 15px;
  padding: 20px;
  border-radius: 15px;
}

/* BOTÃO */
.btn {
  display: block;
  margin: 30px auto;
  background: white;
  color: #6A0DAD;
  padding: 12px 25px;
  border-radius: 10px;
  text-align: center;
  width: 200px;
  font-weight: bold;
  text-decoration: none;
}

/* WHATSAPP FIXO */
.whatsapp {
  position: fixed;
  bottom: 20px;
  right: 20px;
  background: #25D366;
  color: white;
  padding: 15px;
  border-radius: 50%;
  font-size: 20px;
  text-decoration: none;
}
</style>

</head>

<body>

<!-- MENU -->
<nav>
  <a href="#">Início</a>
  <a href="#">Renda</a>
  <a href="#">Investimentos</a>
</nav>

<!-- HEADER -->
<header>
  <h1>CHINAMIDIA</h1>
  <p>Do zero à liberdade financeira</p>
</header>

<!-- CONTEÚDO -->
<div class="container">

  <div class="box">
    <h2>Controle Financeiro</h2>
    <p>Organize tudo que entra e sai.</p>
  </div>

  <div class="box">
    <h2>Reserva de Emergência</h2>
    <p>Tenha segurança antes de investir.</p>
  </div>

  <div class="box">
    <h2>Investimentos</h2>
    <p>Faça seu dinheiro trabalhar por você.</p>
  </div>

  <div class="box">
    <h2>Renda Extra</h2>
    <p>Aprenda a ganhar mais e crescer rápido.</p>
  </div>

</div>

<a class="btn" href="#">Começar Agora</a>

<!-- BOTÃO WHATSAPP -->
<a class="whatsapp" href="https://wa.me/55SEUNUMERO" target="_blank">💬</a>

</body>
</html>
